# Caching headers for the deployed static site.
#
# Files at the root of this directory (which is the deploy branch's
# contents, copied by Hostinger to <docroot>/thecivil/) — index.html,
# _next/static/*, images/*, etc. No URL rewrites are needed because
# every HTML file already lives at the path it's served from.

<IfModule mod_headers.c>
  # Content-hashed assets (Next.js _next/static, images) — immutable forever.
  <FilesMatch "\.(js|css|woff2?|svg|png|jpg|jpeg|webp|avif|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML and text — short cache so updates are visible quickly.
  <FilesMatch "\.(html|webmanifest|xml|txt)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>

AddType image/svg+xml .svg
AddType application/manifest+json .webmanifest
AddDefaultCharset utf-8
